{
  "version": "0.2",
  "language": "en",
  "useGitignore": true,
  "allowCompoundWords": true,
  "ignorePaths": ["node_modules", "dist", ".astro"],
  "ignoreRegExpList": ["/<[^>]*>/g", "/\\{[^}]*\\}/g"],
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": "./cspell-dict.txt"
    }
  ],
  "dictionaries": ["project-words"]
}
