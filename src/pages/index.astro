---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Çağatay Sunal">
  <h1>Çağatay Sunal</h1>
  <p class="muted">Backend Developer</p>

  <div class="card">
    <p>
      Backend-focused developer with 2 years of Android (Flutter) experience. I
      care about depth, clean systems, and building software that lasts.
    </p>
  </div>

  <h2>Currently Building</h2>

  <h2>Latest</h2>
  <ul class="post-list">
    {
      posts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}/`}>
            <span>{post.data.title}</span>
            <span class="muted">
              {post.data.pubDate.toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
  <p><a href="/blog">View all →</a></p>
</BaseLayout>

<style>
  .project-list {
    display: grid;
    gap: 0.75rem;
  }
  .post-list {
    list-style: none;
    padding: 0;
  }
  .post-list li {
    margin-bottom: 0.5rem;
  }
  .post-list a {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    text-decoration: none;
  }
  .post-list a:hover span:first-child {
    text-decoration: underline;
  }
</style>
